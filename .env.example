# ===== Copia este archivo a .env y rellena los valores =====
# El .env real NUNCA se versiona (está en .gitignore)

# ---- App ----
APP_NAME="AI World Cup 2026"
ENVIRONMENT=development            # development | production
DEBUG=true

# ---- Seguridad / JWT ----
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Admin semilla (se crea al iniciar si no existe) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-password
ADMIN_EMAIL=admin@local

# ---- Base de datos ----
DATABASE_URL=sqlite:///./data/app.db

# ---- CORS (solo si usas topología de hosts separados; con reverse-proxy único déjalo vacío) ----
# Ej: https://192.168.1.60  (IP/host del Servidor B)
CORS_ORIGINS=

# ---- Fuentes de datos ----
# Dataset histórico (GitHub raw, sin auth). Alternativa: Kaggle martj42.
RESULTS_CSV_URL=https://raw.githubusercontent.com/martj42/international_results/master/results.csv
SHOOTOUTS_CSV_URL=https://raw.githubusercontent.com/martj42/international_results/master/shootouts.csv

# ---- Datos en vivo (opcional). El scheduler usa football-data.org si hay token; si no, API-Football. ----

# football-data.org (RECOMENDADO, gratis): su tier libre SÍ cubre el Mundial 2026.
# Regístrate gratis en https://www.football-data.org/client/register y pega el token.
FOOTBALL_DATA_ORG_TOKEN=
FOOTBALL_DATA_ORG_BASE=https://api.football-data.org/v4

# API-Football (api-sports.io): el plan FREE NO cubre la temporada 2026 (solo 2022-2024).
# Útil solo con plan de pago. Cabecera x-apisports-key.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io

LIVE_SYNC_INTERVAL_MINUTES=15

# ---- Simulación ----
MONTE_CARLO_RUNS=10000

# ---- Despliegue (lo usa el Caddyfile del Servidor B) ----
# IP del Servidor A (este equipo) vista desde el Servidor B
SERVIDOR_A_IP=192.168.1.50
SERVIDOR_A_PORT=8000
